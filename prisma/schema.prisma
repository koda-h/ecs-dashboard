generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Admin
  Editor
  Viewer
}

enum ViewMode {
  ALL
  SYNC
  CUSTOM
}

model User {
  id        String   @id @default(cuid())
  userId    String   @unique // ユーザが設定した半角英数字ID
  email     String   @unique
  password  String   // bcrypt ハッシュ済み
  role      UserRole @default(Viewer)
  viewMode  ViewMode @default(ALL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accountLock         AccountLock?
  passwordResetTokens PasswordResetToken[]
  servicePermissions  ServicePermission[]
  viewPermissions     ViewPermission[]
}

// Editor ユーザに付与する ECS サービス操作権限
model ServicePermission {
  id          String   @id @default(cuid())
  userId      String   // User.id (内部ID)
  clusterArn  String
  clusterName String
  serviceArn  String
  serviceName String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceArn])
}

// Editor / Viewer ユーザに付与する ECS サービス閲覧権限（viewMode: CUSTOM 時に参照）
model ViewPermission {
  id          String   @id @default(cuid())
  userId      String   // User.id (内部ID)
  clusterArn  String
  clusterName String
  serviceArn  String
  serviceName String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceArn])
}

// ログイン失敗によるアカウントロック状態
model AccountLock {
  id           String    @id @default(cuid())
  userId       String    @unique // User.id (内部ID)
  failureCount Int       @default(0)
  lockedAt     DateTime?
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// パスワードリセット用トークン（有効期限1時間）
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique // SHA-256 ハッシュ済みトークン
  userId    String    // User.id (内部ID)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
