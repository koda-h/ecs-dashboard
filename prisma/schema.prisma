generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  userId              String               @unique
  email               String               @unique
  password            String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  role                UserRole             @default(Viewer)
  viewMode            ViewMode             @default(ALL)
  webAuthnUserId      String?              @unique
  accountLock         AccountLock?
  passwordResetTokens PasswordResetToken[]
  servicePermissions  ServicePermission[]
  viewPermissions     ViewPermission[]
  passkeys            Passkey[]
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  name         String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String
  backedUp     Boolean   @default(false)
  transports   String[]
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  userId    String?
  challenge String   @unique
  type      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ServicePermission {
  id          String   @id @default(cuid())
  userId      String
  clusterArn  String
  clusterName String
  serviceArn  String
  serviceName String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceArn])
}

model ViewPermission {
  id          String   @id @default(cuid())
  userId      String
  clusterArn  String
  clusterName String
  serviceArn  String
  serviceName String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceArn])
}

model AccountLock {
  id           String    @id @default(cuid())
  userId       String    @unique
  failureCount Int       @default(0)
  lockedAt     DateTime?
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  Admin
  Editor
  Viewer
}

enum ViewMode {
  ALL
  SYNC
  CUSTOM
}
