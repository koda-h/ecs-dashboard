# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ポート設定（docker-compose と共有する単一定義）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ホスト側ポート。変更する場合はここだけ修正すれば docker-compose にも反映される
POSTGRES_HOST_PORT=51432
SMTP_HOST_PORT=12025
SMTP_UI_HOST_PORT=12080

# データベース接続文字列（ポートは上記変数から展開）
DATABASE_URL="postgresql://postgres:password@localhost:${POSTGRES_HOST_PORT}/ecsdashboard"

# JWT 署名シークレット（本番では openssl rand -base64 32 で生成してください）
JWT_SECRET="change-me-to-a-random-32-char-secret-key"

# メール送信設定（ポートは上記変数から展開）
SMTP_HOST="localhost"
SMTP_PORT="${SMTP_HOST_PORT}"
# SMTP_USER="your-smtp-user"   # 本番SMTPサーバを使う場合
# SMTP_PASS="your-smtp-pass"
# SMTP_SECURE="true"           # TLS を使う場合
MAIL_FROM="noreply@ecs-dashboard.local"

# アプリのベースURL（パスワードリセットメールのリンク生成に使用）
NEXT_PUBLIC_APP_URL="http://localhost:3000"
